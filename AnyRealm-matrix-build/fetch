# 2. Force rigid hardware execution permission flags across the native binaries
chmod 755 unpackbootimg mkbootimg lz4

echo "=========================================================="
echo "[+] SUCCESS: STANDALONE ARM64 AOSP TOOLS STAGED NATIVELY!"
echo "=========================================================="
ls -lh unpackbootimg mkbootimg lz4

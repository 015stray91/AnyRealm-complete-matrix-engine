WORKSPACE_TOOLS="/data/local/tmp/anyrealm_swap_factory/tools"
mkdir -p "$WORKSPACE_TOOLS" && cd "$WORKSPACE_TOOLS"

echo "=========================================================="
echo "[*] Ingesting standalone static ARM64 AOSP extraction and compilation binaries..."
echo "=========================================================="

# 1. Fetch official, static native ARM64 binaries (No Python/No script wrappers)
# These direct paths pull pre-compiled C/C++ native executables built for on-device terminal use
wget -q "https://github.com/015stray91/Asop-img-tool.git" -O unpackbootimg
wget -q "https://github.com/015stray91/Asop-img-tool.git" -O mkbootimg
